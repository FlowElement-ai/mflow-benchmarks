{
  "engine": "mflow",
  "version": "0.3.2",
  "deployment": "Docker (self-hosted)",
  "dataset": "LongMemEval Oracle",
  "questions_evaluated": 100,
  "ingestion": {
    "precise_mode": true,
    "episode_routing": false,
    "content_type": "DIALOG",
    "per_session_add_then_memorize": true,
    "created_at_from_dataset": true
  },
  "evaluation": {
    "answer_model": "gpt-5-mini",
    "judge_model": "gpt-4o-mini",
    "retrieval_top_k": 10,
    "retrieval_method": "EpisodicRetriever (triplet completion)",
    "metrics": [
      "LLM-Judge Accuracy",
      "BLEU-1",
      "F1"
    ]
  },
  "models": {
    "ingestion_llm": "gpt-5-nano",
    "embedding": "text-embedding-3-small (1536d)",
    "graph_db": "KuzuDB (per-dataset isolation)",
    "vector_db": "LanceDB (per-dataset isolation)"
  }
}